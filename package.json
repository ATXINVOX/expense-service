{
  "name": "expense-service-tests",
  "version": "1.0.0",
  "description": "Cypress API BDD tests for expense-service",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:api": "cypress run --spec 'cypress/e2e/features/**/*.feature'"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^20.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.0.0",
    "cypress": "^13.0.0",
    "esbuild": "^0.19.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/support/step_definitions/**/*.js",
    "nonGlobalStepDefinitions": false,
    "json": {
      "enabled": true,
      "output": "cypress/cucumber-json/results.json"
    }
  }
}
